{
  "name": "matchamap-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MatchaMap - Curated guide to matcha cafes in Toronto",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=frontend",
    "deploy:backend": "npm run deploy --workspace=backend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply matchamap-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply matchamap-db --remote",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "typescript": "^5.2.2"
  }
}