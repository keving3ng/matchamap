{
  "name": "matchamap-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "MatchaMap - Curated guide to matcha cafes in Toronto",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=frontend",
    "deploy:backend": "npm run deploy --workspace=backend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace=frontend",
    "test:ci": "npm run test:ci --workspace=frontend",
    "test:all": "npm run test:ci --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:integration": "vitest run tests/integration",
    "test:integration:watch": "vitest tests/integration",
    "test:all-comprehensive": "npm run test:all && npm run test:integration && npm run test:e2e",
    "lint": "npm run lint --workspace=frontend",
    "lint:ci": "npm run lint:ci --workspace=frontend || true",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply matchamap-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply matchamap-db --remote",
    "deploy": "wrangler deploy",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.1",
    "@playwright/test": "^1.40.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "typescript": "^5.2.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run typecheck"
    ],
    "frontend/**/*.{ts,tsx}": [
      "npm run lint --workspace=frontend"
    ]
  },
  "dependencies": {
    "terser": "^5.44.0"
  }
}
