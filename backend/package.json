{
  "name": "@matchamap/backend",
  "version": "1.0.0",
  "description": "MatchaMap backend - Cloudflare Workers + D1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:push": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "wrangler d1 migrations apply matchamap-db"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.0",
    "itty-router": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.2.2",
    "wrangler": "^3.0.0"
  }
}