{
  "name": "matchamap-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run db:migrate:prod && wrangler deploy --env=\"\"",
    "deploy:dev": "npm run db:migrate:prod && wrangler deploy --env dev",
    "deploy:skip-migrations": "wrangler deploy --env=\"\"",
    "deploy:dev:skip-migrations": "wrangler deploy --env dev",
    "tail": "wrangler tail --env=\"\"",
    "tail:dev": "wrangler tail --env dev",
    "db:create": "wrangler d1 create matchamap-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply matchamap-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply matchamap-db --remote",
    "db:seed": "tsx drizzle/seed.ts",
    "db:export": "tsx drizzle/export.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "itty-router": "^5.0.18",
    "jose": "^6.1.1",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.17",
    "@cloudflare/workers-types": "^4.20251014.0",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.6",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.43.0"
  }
}
