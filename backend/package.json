{
  "name": "matchamap-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "db:create": "wrangler d1 create matchamap-db",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply matchamap-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply matchamap-db --remote",
    "db:seed": "tsx drizzle/seed.ts",
    "db:export": "tsx drizzle/export.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "itty-router": "^5.0.18",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "wrangler": "^4.40.3"
  }
}
