{
  "name": "@matchamap/frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "MatchaMap frontend - React + Vite",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=./test-results/junit.xml",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --reporter=default --reporter=junit --outputFile.junit=./test-results/junit.xml",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:ci": "eslint . --report-unused-disable-directives --max-warnings 200",
    "typecheck": "tsc --noEmit",
    "bundle:check": "node scripts/check-bundle-size.js"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.2.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.9.3",
    "react-router-dom": "^7.9.4",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-yaml": "^4.1.2",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/jest-dom": "^6.1.6",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/leaflet": "^1.9.8",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.6",
    "@vitest/ui": "^4.0.6",
    "eslint": "^9.0.0",
    "eslint-formatter-gha": "^2.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.12",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.6"
  }
}
